# ============================================================================
# Atomic Pumpkin Exocortex - Environment Configuration
# Copy to .env and fill in your values
# ============================================================================

# API Keys (required for LLM routing)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# LiteLLM (proxy layer)
LITELLM_MASTER_KEY=sk-change-me-to-random-string
LITELLM_SALT_KEY=generate-with-openssl-rand-base64-32

# Auth
JWT_SECRET=change-me-use-long-random-string

# Encryption (API keys at rest). 32 bytes, base64-encoded.
# Generate: openssl rand -base64 32
# If unset, derives from JWT_SECRET (not recommended for production).
ENCRYPTION_KEY=

# Environment: "production" (default) or "development"
# Production: restrictive CORS, Secure cookies, no debug endpoints.
# Development: permissive CORS, no Secure flag (localhost has no TLS).
ENVIRONMENT=production

# OAuth (optional - for GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# Feature Toggles
# ============================================================================

# MCP Server (SSE transport for Claude Desktop/CLI)
# Integrated into engine - no separate addon needed
MCP_ENABLED=false

# Code Thumbs (multi-language formatter/linter)
# Requires code-thumbs addon OR external service
CODE_THUMBS_ENABLED=false
CODE_THUMBS_URL=http://code-thumbs:8072

# ============================================================================
# Ollama (Local LLM for L1/L3/Monitor)
# ============================================================================

# URL for Ollama API — used by LiteLLM to route ollama/* model calls
# Local dev (Mac): http://host.docker.internal:11434
# Remote (LAN):    http://192.168.0.169:11434
# Containerized:   http://ollama:11434
OLLAMA_API_URL=http://host.docker.internal:11434

# ============================================================================
# Apeifier (L1/L3 compression pipeline)
# ============================================================================

# L1: glyph translation (local, fast, runs on every add/ingest)
# Default: ollama/ministral-3:3b — requires: ollama pull ministral-3:3b
APEIFIER_L1_MODEL=ollama/ministral-3:3b

# L3: teacher model (rewrites failed L1, teaches new patterns)
# Default: claude-haiku-4 (API). For all-local: ollama/gemma3:12b
# Requires: ollama pull gemma3:12b (if using local)
APEIFIER_LLM_MODEL=claude-haiku-4

# L2: validation threshold (semantic similarity to exemplars)
# APEIFIER_EXEMPLAR_THRESHOLD=0.85

# Monitor: quality gate (hardcoded ollama/gemma3:4b)
# Requires: ollama pull gemma3:4b

# ============================================================================
# Advanced Configuration
# ============================================================================

# Databases
APE_DATABASE_URL=postgresql://litellm:litellm_pass@postgres:5432/ape

# Qdrant vector database
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Engine settings
COGNITIVE_ENGINE_ENABLED=true
SESSION_COMPRESSION_ENABLED=true
