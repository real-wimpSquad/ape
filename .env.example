# ============================================================================
# Atomic Pumpkin Exocortex - Environment Configuration
# Copy to .env and fill in your values.
#
# Most settings auto-bootstrap from the database on first run.
# This file is only needed for API keys and optional overrides.
# ============================================================================

# API Keys (at least one required for LLM routing)
# You can also add these later in the web UI: Settings > Server Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# ============================================================================
# Optional Overrides (env var takes priority over DB-stored settings)
# ============================================================================

# These are all managed via the Admin UI by default.
# Only set them here if you need to override the DB value.

# ENVIRONMENT=production
# LITELLM_MASTER_KEY=sk-custom-key
# JWT_SECRET=custom-jwt-secret
# ENCRYPTION_KEY=base64-encoded-32-bytes
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# ADMIN_EMAILS=admin@example.com

# ============================================================================
# Ollama (Local LLM — optional)
# ============================================================================

# URL for Ollama API — used by LiteLLM to route ollama/* model calls
# Local dev (Mac): http://host.docker.internal:11434
# Remote (LAN):    http://192.168.0.169:11434
# Containerized:   http://ollama:11434
# OLLAMA_API_URL=http://host.docker.internal:11434
