# Ignore everything by default
*

# Backups directory
backups/

# But track these root files
!.gitignore
!docker-compose.yml
!migrations/
!migrations/**
!.env.example
!ape.sh
!ape.bat
!ape.example.toml
!README.md
!LICENSE
!Makefile

# Track addon directories and their config files
!addons/
!addons/*/

# Track addon config files
!addons/*/docker-compose*.yml
!addons/*/README.md
!addons/*/*.yaml

# Explicitly ignore data directories
qdrant_data/
vdb_data/
postgres_data/
redis_data/
qdrant/
project_vdb/

# Environment files (only .env.example should be tracked)
.env
.env.*
.env.local
.env.*.local
!.env.example

# Logs
*.log
logs/

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
